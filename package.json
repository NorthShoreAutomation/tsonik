{
  "name": "tsonik",
  "version": "2.0.0",
  "description": "Complete generated TypeScript SDK for the iconik media management API (15 services)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthShoreAutomation/tsonik.git"
  },
  "homepage": "https://github.com/NorthShoreAutomation/tsonik",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./acls": {
      "types": "./dist/acls/index.d.ts",
      "default": "./dist/acls/index.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "default": "./dist/assets/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./automations": {
      "types": "./dist/automations/index.d.ts",
      "default": "./dist/automations/index.js"
    },
    "./files": {
      "types": "./dist/files/index.d.ts",
      "default": "./dist/files/index.js"
    },
    "./jobs": {
      "types": "./dist/jobs/index.d.ts",
      "default": "./dist/jobs/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "default": "./dist/metadata/index.js"
    },
    "./ml": {
      "types": "./dist/ml/index.d.ts",
      "default": "./dist/ml/index.js"
    },
    "./notifications": {
      "types": "./dist/notifications/index.d.ts",
      "default": "./dist/notifications/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "default": "./dist/search/index.js"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "default": "./dist/settings/index.js"
    },
    "./stats": {
      "types": "./dist/stats/index.d.ts",
      "default": "./dist/stats/index.js"
    },
    "./transcode": {
      "types": "./dist/transcode/index.d.ts",
      "default": "./dist/transcode/index.js"
    },
    "./users-notifications": {
      "types": "./dist/users-notifications/index.d.ts",
      "default": "./dist/users-notifications/index.js"
    },
    "./users": {
      "types": "./dist/users/index.d.ts",
      "default": "./dist/users/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
