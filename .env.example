# Iconik API Configuration for Integration Tests
# Copy this file to .env and fill in your actual values

# Iconik App ID (required)
ICONIK_APP_ID=your_app_id_here

# Iconik Auth Token (required)
ICONIK_AUTH_TOKEN=your_auth_token_here

# Iconik Base URL (optional, defaults to https://app.iconik.io)
# ICONIK_BASE_URL=https://app.iconik.io

# Test Configuration
# Set to 'true' to run integration tests that modify data (create/update/delete)
# ICONIK_ALLOW_DESTRUCTIVE_TESTS=false
