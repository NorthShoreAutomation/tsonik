{
  "name": "tsonik-nodes",
  "version": "1.0.4",
  "description": "N8N nodes for Iconik API",
  "keywords": [
    "n8n-community-node-package"
  ],
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "lintfix": "eslint src/**/*.ts --fix",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/IconikApi.credentials.js",
      "dist/credentials/LicenseSpring.credentials.js"
    ],
    "nodes": [
      "dist/nodes/IconikMetadata/IconikMetadata.node.js",
      "dist/nodes/IconikJob/IconikJob.node.js",
      "dist/nodes/IconikFormat/IconikFormat.node.js",
      "dist/nodes/IconikFileset/IconikFileset.node.js",
      "dist/nodes/IconikFile/IconikFile.node.js",
      "dist/nodes/IconikCollection/IconikCollection.node.js",
      "dist/nodes/IconikAsset/IconikAsset.node.js"
    ]
  },
  "dependencies": {
    "@licensespring/node-sdk": "^1.2.0",
    "n8n-workflow": "^1.0.0",
    "tsonik": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.0"
  }
}